# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ROWMATIC - Environment Variables
# Copy this to .env and fill values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# AI Provider: gemini | nvidia | groq | openai | mistral | claude
AI_PROVIDER=gemini

# AI Keys (fill whichever you use)
GEMINI_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public (Vite frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_RAZORPAY_KEY_ID=
